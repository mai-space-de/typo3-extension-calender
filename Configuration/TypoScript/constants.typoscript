# mai_events TypoScript Constants

plugin.tx_maievents {
    view {
        templateRootPath = EXT:mai_events/Resources/Private/Templates/
        partialRootPath = EXT:mai_events/Resources/Private/Partials/
        layoutRootPath = EXT:mai_events/Resources/Private/Layouts/
    }
    settings {
        defaultViewMode = month
        listLimit = 10
    }
}
