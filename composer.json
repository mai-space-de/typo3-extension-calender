{
    "name": "maispace/mai-calendar",
    "description": "TYPO3 Calendar extension with month, week and list views and iCal export",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^12.0 || ^13.0",
        "typo3/cms-frontend": "^12.0 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "typo3/testing-framework": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\MaiCalendar\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\MaiCalendar\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mai_calendar"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
